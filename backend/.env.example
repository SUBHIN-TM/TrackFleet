# ---- Database (PostgreSQL) ----
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trackfleet?schema=public"

# ---- Auth ----
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ---- Server ----
PORT=4004
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"

# ---- Email (SMTP) ----
# Used for org admin invites, login OTPs, and password resets.
# Leave SMTP_HOST blank in dev to print emails to the console instead of sending.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
# The "from" address users see (must be a VERIFIED sender with your provider).
MAIL_FROM="no-reply@example.com"
MAIL_FROM_NAME="TrackFleet"
# Where invite emails tell the org admin to sign in.
ADMIN_PORTAL_URL="http://localhost:5174"
# Base URL of the parent/guardian portal (login by org + phone + password).
# The portal app is not built yet — this is the link the admin shares.
PARENT_PORTAL_URL="http://localhost:5175"

# ---- (Phase 2) Push — leave blank for now ----
FCM_SERVER_KEY=""

# ---- Map & routing ----
# Tiles: public OpenStreetMap raster tiles (fallback if no vector style).
MAP_TILE_URL="https://tile.openstreetmap.org/{z}/{x}/{y}.png"
# Vector map style — labels stay upright when rotating (Google-Maps-like). Free,
# no API key. Set to "" to fall back to raster tiles above. Swap for MapTiler /
# self-hosted in production.
MAP_STYLE_URL="https://tiles.openfreemap.org/styles/liberty"
# Geocoder for the map place-search box (defaults to public Nominatim).
GEOCODER_URL="https://nominatim.openstreetmap.org"
# OSRM road routing (self-hosted on VPS, exposed via token-protected proxy).
OSRM_URL="https://wintransport.duckdns.org/osrm"
OSRM_TOKEN="set-me"
